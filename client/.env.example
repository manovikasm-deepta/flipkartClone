# ── API base URL ────────────────────────────────────────────────────────────────
# Development: Vite dev server proxies /api → http://localhost:5000/api
#              So you can leave this as /api for local dev
# Production:  Set to your Render backend URL
VITE_API_URL=/api

# ── Override for local dev if not using Vite proxy ──────────────────────────────
# VITE_API_URL=http://localhost:5000/api

# ── Production example ──────────────────────────────────────────────────────────
# VITE_API_URL=https://flipkart-clone-api.onrender.com/api
