# ── Server ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database ────────────────────────────────────────────────────────────────────
# Local:   postgresql://postgres:password@localhost:5432/flipkart_dev
# Render:  paste the Internal Database URL from your Render PostgreSQL dashboard
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/flipkart_dev

# ── Authentication ───────────────────────────────────────────────────────────────
# Must be at least 32 random characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_MINIMUM_32_CHARACTER_RANDOM_SECRET_KEY
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────────────────────────
# Development: http://localhost:5173
# Production:  https://your-app.vercel.app
CLIENT_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
