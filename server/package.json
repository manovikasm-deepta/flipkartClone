{
  "name": "flipkart-clone-server",
  "version": "1.0.0",
  "private": true,
  "main": "server.js",
  "scripts": {
    "dev":     "nodemon server.js",
    "start":   "node server.js",
    "lint":    "eslint src/ --ext .js",
    "test":    "jest --forceExit --detectOpenHandles",
    "migrate": "node src/db/migrate.js",
    "seed":    "node src/db/seed.js"
  },
  "dependencies": {
    "bcryptjs":          "^2.4.3",
    "cors":              "^2.8.5",
    "dotenv":            "^16.4.5",
    "express":           "^4.19.2",
    "express-rate-limit":"^7.3.1",
    "express-validator": "^7.1.0",
    "helmet":            "^7.1.0",
    "jsonwebtoken":      "^9.0.2",
    "morgan":            "^1.10.0",
    "pg":                "^8.12.0",
    "uuid":              "^10.0.0"
  },
  "devDependencies": {
    "eslint":    "^8.57.0",
    "jest":      "^29.7.0",
    "nodemon":   "^3.1.4",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch":       ["**/__tests__/**/*.test.js"]
  }
}
